# Copy to .env and edit. docker compose auto-reads .env in the compose dir.
#
# Container-internal listen ports.
API_PORT=8085
METRICS_PORT=9095
#
# Host port mappings. Change these if 8085 / 9095 / 9091 conflict on your machine.
HOST_API_PORT=8085
HOST_METRICS_PORT=9095
HOST_PROMETHEUS_PORT=9091
#
# App config.
HMAC_SECRET=dev_secret_change_in_production
LOG_LEVEL=info
DB_MAX_CONNS=25
DB_MIN_CONNS=5
#
# Native (non-docker) DATABASE_URL. Inside docker compose the api uses the
# postgres service hostname, set in docker-compose.yml.
DATABASE_URL=postgres://paybook_app:paybook_app_pw@localhost:5432/paybook?sslmode=disable
